# --- Required ---

# Local development: SQLite
DATABASE_URL="file:./dev.db"
# Production (Neon PostgreSQL): postgres://user:pass@host/db?sslmode=require
# DATABASE_URL="postgres://..."

# Long random secret for session tokens (generate: openssl rand -base64 32)
AUTH_SECRET="change-me"

# --- Cloud file storage (Cloudflare R2) — required on Vercel, optional elsewhere ---
# When unset, files are stored on the local disk under ./uploads.
# S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
# S3_BUCKET="dcs-world-mods"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"

# --- Google sign-in (optional; button appears only when set) ---
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <APP_URL>/api/auth/google/callback
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# APP_URL="https://your-site.vercel.app"   # public base URL (falls back to request origin)

# --- Password reset emails over SMTP (optional; works with Brevo, Gmail, ...) ---
# SMTP_HOST="smtp-relay.brevo.com"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# EMAIL_FROM="you@example.com"
